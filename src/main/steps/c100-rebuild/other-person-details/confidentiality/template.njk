{% extends "common/template.njk" %}

{# These paths worked in your previous test #}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block page_content %}
  {% include "common/error/summary.njk" %}

  <h1 class="govuk-heading-xl">{{ title }}</h1>
  <p class="govuk-body">{{ line1 }}</p>

  {# This is your dynamic 'lives with' / 'live with' text #}
  <p class="govuk-body">{{ line2 }}</p>

  <form class="form" method="post" action="" novalidate>
    {# RAW CSRF INPUT: This replaces the broken 'macros/csrf.njk' import #}
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    {% block form_content %}
      {# Passing the fields from your TS controller #}
      {{ govukRadios(form.fields.confidentiality) }}
    {% endblock %}

  </form>
{% endblock %}
