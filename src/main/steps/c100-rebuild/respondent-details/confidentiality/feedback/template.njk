{% extends "common/template.njk" %}

{% block page_content %}
<span class="govuk-caption-xl">{{caption}}</span>
<h1 class="govuk-heading-xl govuk-!-margin-bottom-7">{{headingTitle}}</h1>
<p class="govuk-body-m">{{paragraphOne}}</p>
<ul class="govuk-list govuk-list--bullet">
{% for item in listOfBullets %}
  {% if item !== "" %}
    <li>{{item}}</li>
  {% endif %}
{% endfor %}
</ul>
<h2 class="govuk-heading-m">{{heading3}}</h2>
<p class="govuk-body-m govuk-!-margin-bottom-9">{{paragraphTwo}}</p>
{% endblock %}
