{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block page_content %}
<br/>
<a href="/applicant/task-list" class="govuk-link">DA Applicant</a>
<br />
<br />
<a href="/ca-da-respondent/task-list" class="govuk-link">CA DA Respondent</a>
<br/>
<h1 class="govuk-heading-l">Create C100 Application</h1>
<a href="/c100-rebuild/confidentiality/details-know" class="govuk-button">Start Now</a>
