    }
  ]
}) }}

{% endif %}
<ul class="govuk-list">
  <li>
    <a class="govuk-link" href="/applicant/task-list">DA Applicant</a>
  </li>
  <li>
    <a class="govuk-link" href="/ca-da-respondent/task-list">CA DA Respondent</a>
  </li>
  <li>
    <a class="govuk-link" href="/c100-rebuild">C100 Application</a>
  </li>
</ul>

<a class='govuk-button' href='/payments/gateway'>Pay Now </a>

{% endblock %}
